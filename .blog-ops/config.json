{
  "timezone": "Asia/Shanghai",
  "ai": {
    "text": {
      "provider": "openai",
      "model": "deepseek-ai/DeepSeek-V4-Flash",
      "base_url": "https://api.siliconflow.cn/v1",
      "api_key_env": "OPENAI_API_KEY"
    },
    "image": {
      "provider": "workers_ai",
      "model": "@cf/black-forest-labs/flux-2-klein-4b",
      "account_id_env": "CF_IMAGE_ACCOUNT_ID",
      "api_token_env": "CF_IMAGE_API_TOKEN"
    }
  },
  "search": {
    "provider": "tavily",
    "api_key_env": "TAVILY_API_KEY"
  },
  "schedule": {
    "weekly_min": 2,
    "weekly_target": 3,
    "wednesday_checkpoint": true,
    "saturday_checkpoint": true
  },
  "writing": {
    "min_words": 800,
    "max_words": 1500,
    "min_images": 1,
    "target_images": 2
  }
}
